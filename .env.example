# HiNikki environment — copy to .env and fill in (public anon key only, never the service-role key)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Voice-lab spike ONLY (app/voice-lab.tsx): a PUBLIC ElevenLabs test agent with no real data.
# Production voice never needs an agent id client-side — the private agent is reached through
# tokens minted by the elevenlabs-token Edge Function (secrets set via `supabase secrets set`).
EXPO_PUBLIC_ELEVENLABS_AGENT_ID=
